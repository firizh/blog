<%
/**
 * Single post page template.
 *
 * Layout: Left Sidebar (TOC/category bar) | Main Content (article) | Right Sidebar (TOC/floating TOC)
 *
 * Variables available:
 *   page       - current post page
 *   site       - Hexo site object
 *   config     - Hexo site configuration
 *   theme      - theme _config.yml values
 *   post       - alias for page (Hexo convention)
 *   __()       - i18n function
 */
var post = page;
var tocConfig = theme.post && theme.post.toc || {};
var categoryBarConfig = theme.post && theme.post.category_bar || {};
var showToc = tocConfig.enable && post.toc !== false;

// Determine sidebar positions
var sidebar = theme.sidebar || {};
var sidebarPosition = sidebar.position || 'both';
var showLeftSidebar = sidebarPosition === 'both' || sidebarPosition === 'left';
var showRightSidebar = sidebarPosition === 'both' || sidebarPosition === 'right';

// TOC placement
var tocPlacement = tocConfig.placement || 'right';
var tocInLeft = showToc && tocPlacement === 'left';
var tocInRight = showToc && tocPlacement !== 'left';
var tocFloating = showToc && tocConfig.floating !== false;

// Category bar placement for post
var catBarPlacement = categoryBarConfig.placement || 'left';
var showCatBarInLeft = showLeftSidebar && categoryBarConfig.enable && catBarPlacement !== 'right' && !post.hide;
var showCatBarInRight = showRightSidebar && categoryBarConfig.enable && catBarPlacement === 'right' && !post.hide;

var actualLeft = (showLeftSidebar || tocInLeft || showCatBarInLeft);
var actualRight = (showRightSidebar || tocInRight || showCatBarInRight);
var gridClass = 'has-no-sidebar';
if (actualLeft && actualRight) {
  gridClass = 'has-both-sidebars';
} else if (actualLeft) {
  gridClass = 'has-left-sidebar';
} else if (actualRight) {
  gridClass = 'has-right-sidebar';
}
%>

<div id="main-grid" class="main-grid-layout <%= gridClass %>">
  <!-- ===== Left Sidebar ===== -->
  <% if (showLeftSidebar || tocInLeft || showCatBarInLeft) { %>
  <aside class="sidebar-left" aria-label="<%= __('sidebar.left') %>">
    <% if (showLeftSidebar) { %>
      <%- partial('_partials/post/sidebar-left') %>
    <% } %>
    <% if (tocInLeft) { %>
      <%- partial('_partials/post/toc') %>
    <% } %>
    <% if (showCatBarInLeft) { %>
      <%- partial('_partials/post/category-bar') %>
    <% } %>
  </aside>
  <% } %>

  <!-- ===== Main Content ===== -->
  <main id="main-content" aria-label="<%= __('article') %>">
    <%- partial('_partials/post/content-nav') %>
    <article class="post-container" itemscope itemtype="http://schema.org/Article">


      <div class="post-content-card">
        <!-- Post meta top: title, date, author, reading time, word count, categories -->
        <%- partial('_partials/post/meta-top') %>

        <% if (post.cover || post.thumbnail || post.index_img || post.banner_img) { %>
        <% var coverImg = post.cover || post.thumbnail || post.index_img || post.banner_img; %>
        <div class="post-cover">
          <img src="<%= url_for(coverImg) %>" alt="<%= post.title %>" itemprop="image">
        </div>
        <% } %>

        <!-- Post content -->
        <div
          class="post-content markdown-body custom-md"
          itemprop="articleBody"
        >
          <%- post.content %>
        </div>

        <!-- Post license / copyright -->
        <% if (theme.post && theme.post.copyright && theme.post.copyright.enable && post.copyright !== false) { %>
          <%- partial('_partials/post/copyright') %>
        <% } %>

        <!-- Post meta bottom: tags, last modified -->
        <%- partial('_partials/post/meta-bottom') %>
      </div>

      <!-- Share buttons -->
      <% if (theme.post && theme.post.share && theme.post.share.enable) { %>
      <div class="post-share">
        <span class="post-share-label"><%= __('post.share') %></span>
        <div class="post-share-buttons">
          <% if (theme.post.share.twitter !== false) { %>
          <a href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent(post.title) %>&url=<%= encodeURIComponent(post.permalink) %>"
             target="_blank" rel="noopener noreferrer" class="share-btn share-twitter" aria-label="Share on Twitter">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <% } %>
          <% if (theme.post.share.facebook !== false) { %>
          <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(post.permalink) %>"
             target="_blank" rel="noopener noreferrer" class="share-btn share-facebook" aria-label="Share on Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <% } %>
          <% if (theme.post.share.weibo !== false) { %>
          <a href="https://service.weibo.com/share/share.php?title=<%= encodeURIComponent(post.title) %>&url=<%= encodeURIComponent(post.permalink) %>"
             target="_blank" rel="noopener noreferrer" class="share-btn share-weibo" aria-label="Share on Weibo">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M10.098 20.323c-3.977.391-7.414-1.406-7.672-4.02-.259-2.609 2.759-5.047 6.74-5.441 3.979-.394 7.413 1.404 7.671 4.018.259 2.6-2.759 5.049-6.739 5.443zm-4.33-7.284c-1.053.258-1.79.938-1.691 1.532.095.592.967.862 2.02.603 1.056-.259 1.79-.939 1.69-1.533-.096-.593-.968-.863-2.019-.602zm3.614 4.426c-2.545 1.158-4.669.751-5.089-.515-.42-1.266 1.223-2.98 3.768-4.138 2.544-1.159 4.668-.753 5.088.515.419 1.266-1.223 2.979-3.767 4.138zm2.88-2.655c-.343.108-.567-.217-.496-.725.067-.506.437-.993.82-1.087.382-.094.606.23.539.737-.067.506-.437.993-.863 1.075zM20.604 6.5c-.217-.652-1.308-.919-2.366-.589-1.057.33-1.722 1.13-1.481 1.781.241.651 1.331.917 2.388.588 1.057-.329 1.722-1.129 1.459-1.78zm-2.435-2.932c-.693-.457-2.02-.142-3.119.716-1.1.859-1.478 1.937-.786 2.394.693.457 2.068.135 3.168-.724 1.1-.86 1.479-1.937.737-2.386zm4.584 6.14c-.115-.531-1.015-.825-1.948-.641-.93.183-1.632.821-1.517 1.353.117.531 1.016.825 1.947.64.932-.183 1.633-.821 1.518-1.352zm-1.015-1.576c-.465-.204-1.179.019-1.531.479-.355.462-.226 1.025.241 1.229.464.204 1.179-.019 1.534-.48.352-.461.224-1.025-.244-1.228z"/></svg>
          </a>
          <% } %>
        </div>
      </div>
      <% } %>

      <!-- Prev / Next post navigation -->
      <% if (theme.post && theme.post.prev_next && theme.post.prev_next.enable !== false) { %>
      <nav class="post-navigation" aria-label="<%= __('post.navigation') %>">
        <div class="post-nav-item post-nav-prev">
          <% if (post.prev) { %>
          <a href="<%= url_for(post.prev.path) %>" rel="prev" title="<%= post.prev.title %>">
            <span class="nav-label"><%= __('post.prev_post') %></span>
            <span class="nav-title"><%= post.prev.title %></span>
          </a>
          <% } %>
        </div>
        <div class="post-nav-item post-nav-next">
          <% if (post.next) { %>
          <a href="<%= url_for(post.next.path) %>" rel="next" title="<%= post.next.title %>">
            <span class="nav-label"><%= __('post.next_post') %></span>
            <span class="nav-title"><%= post.next.title %></span>
          </a>
          <% } %>
        </div>
      </nav>
      <% } %>

      <!-- Related posts -->
      <% if (theme.post && theme.post.related && theme.post.related.enable) { %>
      <div class="related-posts">
        <h3 class="related-posts-title"><%= __('post.related_posts') %></h3>
        <div class="related-posts-grid">
          <%- related_posts({ maxCount: theme.post.related.maxCount || 6 }) %>
        </div>
      </div>
      <% } %>
    </article>

    <!-- Comments section -->
    <% if (theme.comments && theme.comments.type && theme.comments.type !== 'none' && post.comments !== false) { %>
    <section class="post-comments" aria-label="<%= __('comments') %>">
      <%- partial('_partials/comments/' + theme.comments.type) %>
    </section>
    <% } %>
  </main>

  <!-- ===== Right Sidebar ===== -->
  <% if (showRightSidebar || tocInRight || showCatBarInRight) { %>
  <aside class="sidebar-right" aria-label="<%= __('sidebar.right') %>">
    <% if (showRightSidebar) { %>
      <%- partial('_partials/post/sidebar-right') %>
    <% } %>
    <% if (tocInRight) { %>
      <%- partial('_partials/post/toc') %>
    <% } %>
    <% if (showCatBarInRight) { %>
      <%- partial('_partials/post/category-bar') %>
    <% } %>
  </aside>
  <% } %>

  <!-- ===== Mobile Bottom Sidebar (visible only on mobile) ===== -->
  <%- partial('_partials/post/mobile-sidebar') %>

  <!-- Floating TOC (always available via JS, appears as a floating widget on scroll) -->
  <% if (tocFloating && !tocInLeft && !tocInRight) { %>
  <div class="toc-floating">
    <%- partial('_partials/post/toc') %>
  </div>
  <% } %>

  <%- partial('_partials/footer') %>
</div>
