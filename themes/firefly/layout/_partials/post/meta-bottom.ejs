<%
/**
 * Post meta-bottom: tags list and last modified info.
 * Used at the bottom of single post pages.
 *
 * Variables available:
 *   page - current post page
 *   theme - theme configuration
 */
var tags = page.tags || [];
%>

<footer class="post-meta-bottom">
  <!-- Tags list -->
  <% if (theme.post.meta && theme.post.meta.tag && theme.post.meta.tag.enable !== false && tags.length > 0) { %>
  <div class="post-meta-tags">
    <span class="material-symbols-outlined" aria-hidden="true">sell</span>
    <% tags.each(function(tag) { %>
      <a href="<%= url_for(tag.path) %>" class="post-tag-link">
        <%- tag.name %>
      </a>
    <% }); %>
  </div>
  <% } %>

  <!-- Categories list at bottom -->
  <% if (theme.post.meta && theme.post.meta.category && theme.post.meta.category.enable !== false && page.categories && page.categories.length > 0) { %>
  <div class="post-meta-categories-bottom">
    <span class="material-symbols-outlined" aria-hidden="true">folder</span>
    <% page.categories.each(function(cat) { %>
      <a href="<%= url_for(cat.path) %>" class="post-category-link">
        <%- cat.name %>
      </a>
    <% }); %>
  </div>
  <% } %>

  <!-- Last modified date -->
  <% if (theme.post.updated && theme.post.updated.enable && page.updated && compare_date(page.date, page.updated)) { %>
  <div class="post-last-modified">
    <span class="material-symbols-outlined" aria-hidden="true">edit</span>
    <%- __('post.last_modified', date(page.updated, theme.post.updated.date_format || config.date_format)) %>
  </div>
  <% } %>
</footer>
