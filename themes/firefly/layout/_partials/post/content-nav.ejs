<%
var currentPath = page.path || '';
var isHome = is_home();
var isPost = is_post();
var isArchive = is_archive();
var isCategory = is_category();
var isTag = is_tag();
var postListDefault = theme.post_list_layout && theme.post_list_layout.default_mode || 'list';
%>
<div class="content-nav-bar card-base">
  <!-- Home button -->
  <a href="<%= url_for('/') %>" class="content-nav-item content-nav-home<%= isHome ? ' active' : '' %>" aria-label="Home" title="<%= __('home') %>">
    <span class="material-symbols-outlined">home</span>
  </a>
  
  <!-- Archive button -->
  <a href="<%= url_for('/archives') %>" class="content-nav-item<%= (isArchive || page.layout === 'archive' || currentPath.indexOf('archives') === 0) ? ' active' : '' %>">
    <span class="nav-item-label">归档</span>
    <span class="nav-item-count"><%= site.posts.length %></span>
  </a>

  <!-- Dynamic Categories -->
  <%
  var displayCats = [];
  if (site.categories && site.categories.length > 0) {
    displayCats = site.categories.filter(function(cat) { return cat.length > 0; }).toArray();
    displayCats.sort(function(a, b) { return b.length - a.length; });
    displayCats = displayCats.slice(0, 3); // Top 3 categories
  }
  if (displayCats && displayCats.length > 0) {
    displayCats.forEach(function(cat) {
      var isCurrentCat = false;
      if (isCategory && page.category === cat.name) {
        isCurrentCat = true;
      } else if (isPost && page.categories && page.categories.length > 0) {
        isCurrentCat = page.categories.some(function(postCat) {
          return postCat.name === cat.name;
        });
      }
  %>
    <a href="<%= url_for(cat.path) %>" class="content-nav-item<%= isCurrentCat ? ' active' : '' %>">
      <span class="nav-item-label"><%= cat.name %></span>
      <span class="nav-item-count"><%= cat.posts.length %></span>
    </a>
  <%
    });
  }
  %>

  <!-- Layout Toggle (right-aligned spacer + buttons) -->
  <% if (isHome || isArchive || page.layout === 'archive' || isCategory || isTag) { %>
  <span class="content-nav-spacer"></span>
  <div class="layout-buttons" style="display:flex;gap:0.25rem;">
    <button data-layout="list" class="<%= postListDefault === 'list' ? 'active' : '' %>" title="<%= __('list') %>">
      <span class="material-symbols-outlined">view_list</span>
    </button>
    <button data-layout="grid" class="<%= postListDefault === 'grid' ? 'active' : '' %>" title="<%= __('grid') %>">
      <span class="material-symbols-outlined">grid_view</span>
    </button>
  </div>
  <% } %>
</div>
