<%
/**
 * Post meta-top: title, date, author, reading time, word count, category/tag path.
 * Used at the top of single post pages.
 *
 * Variables available:
 *   page - current post page
 *   theme - theme configuration
 *   config - Hexo site configuration
 */
var meta = (theme.post && theme.post.meta) || {};
var isBannerMode = theme.wallpaper && theme.wallpaper.mode === 'banner';
%>

<header class="post-meta-top">
    <!-- Top row: Word count & Reading time pills -->
    <div class="post-header-badges-top">
      <% if (meta.wordcount && meta.wordcount.enable) { %>
      <span class="post-meta-badge badge-wordcount">
        <span class="material-symbols-outlined" aria-hidden="true">trending_up</span>
        <span><%- __('post.meta.wordcount', wordcount(page)) %></span>
      </span>
      <% } %>

      <% if (meta.min2read && meta.min2read.enable) { %>
      <span class="post-meta-badge badge-reading-time">
        <span class="material-symbols-outlined" aria-hidden="true">schedule</span>
        <span>
          <% var awl = parseInt(meta.min2read.awl, 10) || 0; %>
          <% var wpm = parseInt(meta.min2read.wpm, 10) || 0; %>
          <%- min2read(page, { awl: awl, wpm: wpm }) %> <%= __('min_read') || '分钟' %>
        </span>
      </span>
      <% } %>
    </div>

    <!-- Title with CSS-styled vertical bar prefix -->
    <h1 class="post-title post-title-custom">
      <strong><%= page.title %></strong>
    </h1>

    <!-- Bottom row: Date & Categories/Tags path -->
    <div class="post-header-badges-bottom">
      <% if (meta.date && meta.date.enable !== false) { %>
      <span class="post-meta-badge badge-date">
        <span class="material-symbols-outlined" aria-hidden="true">calendar_month</span>
        <time datetime="<%= full_date(page.date, 'YYYY-MM-DD HH:mm') %>" pubdate>
          <%- full_date(page.date, (meta.date.format || config.date_format)) %>
        </time>
      </span>
      <% } %>

      <!-- Categories & Tags Breadcrumb Path -->
      <% 
        var pathItems = [];
        if (page.categories && page.categories.length > 0) {
          page.categories.each(function(cat) {
            pathItems.push({ name: cat.name, path: url_for(cat.path), isCategory: true });
          });
        }
        if (page.tags && page.tags.length > 0) {
          page.tags.each(function(tag) {
            pathItems.push({ name: tag.name, path: url_for(tag.path), isCategory: false });
          });
        }
      %>
      <% if (pathItems.length > 0) { %>
      <span class="post-meta-badge badge-taxonomy">
        <span class="material-symbols-outlined" aria-hidden="true">sell</span>
        <span class="taxonomy-path">
          <% pathItems.forEach(function(item, idx) { %>
            <% if (idx > 0) { %>
              <span class="taxonomy-separator">/</span>
            <% } %>
            <a href="<%= item.path %>" class="<%= item.isCategory ? 'taxonomy-cat' : 'taxonomy-tag' %>">
              <%= item.name %>
            </a>
          <% }); %>
        </span>
      </span>
      <% } %>
    </div>

    <!-- Post updated notice -->
    <% if (theme.post && theme.post.updated && theme.post.updated.enable && page.updated && compare_date(page.date, page.updated)) { %>
    <div class="post-updated-note">
      <span class="material-symbols-outlined" aria-hidden="true">update</span>
      <%- __('post.updated', date(page.updated, theme.post.updated.date_format || config.date_format)) %>
    </div>
    <% } %>
</header>
